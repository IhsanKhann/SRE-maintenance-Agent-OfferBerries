{
  "name": "sre-agent",
  "version": "1.0.0",
  "description": "OfferBerries SRE Agent Daemon — autonomous infrastructure operations",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec \"node --loader ts-node/esm src/index.ts\"",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs --forceExit",
    "test:unit": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs tests/unit --forceExit",
    "test:integration": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs tests/integration --forceExit",
    "test:e2e": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs tests/e2e --forceExit",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs --coverage --forceExit",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs --watch"
  },
  "imports": {
    "#config": "./src/config.ts",
    "#db/*": "./src/db/*.ts",
    "#models/*": "./src/db/models/*.ts",
    "#collector/*": "./src/collector/*.ts",
    "#detector/*": "./src/detector/*.ts",
    "#incident/*": "./src/incident/*.ts",
    "#ai/*": "./src/ai/*.ts",
    "#executor/*": "./src/executor/*.ts",
    "#analytics/*": "./src/analytics/*.ts",
    "#scheduler/*": "./src/scheduler/*.ts",
    "#comms/*": "./src/comms/*.ts",
    "#api/*": "./src/api/*.ts",
    "#utils/*": "./src/utils/*.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@google/generative-ai": "^0.24.1",
    "@types/cors": "^2.8.19",
    "@types/nodemailer": "^8.0.0",
    "axios": "^1.12.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "groq-sdk": "^0.9.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.17.0",
    "node-cron": "^4.2.1",
    "node-ssh": "^13.2.0",
    "nodemailer": "^8.0.10",
    "socket.io": "^4.8.3",
    "twilio": "^5.4.0",
    "winston": "^3.19.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.0",
    "@types/supertest": "^7.2.0",
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  }
}
