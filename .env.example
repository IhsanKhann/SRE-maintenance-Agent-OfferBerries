# ── SRE Agent Environment Variables ──────────────────────────────────────────
# Copy to .env and fill in all values.
# Values marked REQUIRED must be set. Values marked OPTIONAL have defaults.

# ── Node ──────────────────────────────────────────────────────────────────────
NODE_ENV=development                    # development | production

# ── SRE Agent Server ─────────────────────────────────────────────────────────
SRE_PORT=3500
SRE_PUBLIC_URL=http://localhost:3500    # REQUIRED — used in email action links

# ── Production Backend-A (OfferBerries) ──────────────────────────────────────
PROD_BACKEND_METRICS_URL=http://localhost:5000/metrics
PROD_BACKEND_HEALTH_URL=http://localhost:5000/api/health
PROD_LOKI_URL=http://localhost:3100
PROD_REDIS_URL=redis://localhost:6379
PROD_SSH_HOST=localhost                 # In prod: Hetzner private network IP
PROD_SSH_USER=deploy
PROD_SSH_KEY_PATH=./ssh_deploy_key      # Path to SSH private key file

# ── MongoDB (SRE Agent database — separate from Backend-A) ───────────────────
# REQUIRED — use a different DB name than Backend-A ("sre_agent" recommended)
MONGODB_SRE_URI=mongodb://localhost:27017/sre_agent

# ── AI APIs ──────────────────────────────────────────────────────────────────

# Fast triage (incident analysis + tool calling)
# REQUIRED — Get from console.groq.com — FREE TIER covers this workload (14,400 req/day)
GROQ_API_KEY=gsk_...

# Code patch generation — choose ONE:

# OPTION A (Recommended — cheapest): Google Gemini 2.0 Flash
# Free tier: 1,500 requests/day — covers 10-30 incidents/month easily
# Get from: aistudio.google.com → Create API Key (no card needed)
GOOGLE_AI_KEY=AIza...

# Which model to use for patches: "gemini" (default, free tier) or "claude"
PATCH_MODEL=gemini

# OPTION B (Fallback): Anthropic Claude — only set if PATCH_MODEL=claude
# $3/M input, $15/M output — ~$4-15/month for your workload
# ANTHROPIC_API_KEY=sk-ant-...

# ── Email / SMTP Notifications ───────────────────────────────────────────────
# REQUIRED — Set up any SMTP provider.
#
# Option A — Gmail (free):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=youremail@gmail.com
#   SMTP_PASS=your_16_char_app_password  (Google Account → Security → App Passwords)
#
# Option B — Resend (free tier 3000 emails/month):
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=465
#   SMTP_SECURE=true
#   SMTP_USER=resend
#   SMTP_PASS=re_xxxxxxxxxxxxxx
#
# Option C — Any SMTP provider (Mailgun, SendGrid, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=youremail@gmail.com
SMTP_PASS=your_app_password_here
ADMIN_EMAIL=youremail@gmail.com          # Where to receive SRE alerts
SMTP_FROM=SRE Agent <sre@yourdomain.com> # Display name (optional)

# ── JWT (reuse same secret as Backend-A for auth continuity) ─────────────────
# REQUIRED — must match Backend-A's JWT_SECRET exactly
JWT_SECRET=your_jwt_secret_here

# ── Hetzner Object Storage (backups) ─────────────────────────────────────────
# OPTIONAL — only needed in production for automated backups
HETZNER_S3_ENDPOINT=https://fsn1.your-objectstorage.com
HETZNER_S3_ACCESS_KEY=...
HETZNER_S3_SECRET_KEY=...
BACKUP_S3_BUCKET=offerberries-backups

# ── Telemetry Collection Intervals ───────────────────────────────────────────
COLLECT_INTERVAL_MS=15000              # how often to poll all sources (default: 15s)
HEALTH_CHECK_INTERVAL_MS=10000         # /api/health polling interval (default: 10s)

# ── Alert Thresholds (override defaults) ─────────────────────────────────────
THRESHOLD_HTTP_ERROR_RATE=0.03         # 3% = alert
THRESHOLD_P95_LATENCY_MS=2000          # 2000ms p95 = alert
THRESHOLD_BULLMQ_FAILED=20             # 20 failed jobs = alert
THRESHOLD_OUTBOX_PENDING=50            # 50 pending outbox events = alert
THRESHOLD_DISK_PERCENT=85              # 85% disk = alert + cleanup
THRESHOLD_MEMORY_PERCENT=85            # 85% container memory = alert

# ── CORS for SRE Dashboard ───────────────────────────────────────────────────
# Comma-separated allowed origins
SRE_CORS_ORIGINS=http://localhost:5174,https://sre.offerberries.com
